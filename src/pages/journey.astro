---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowLeft, Calendar, Code, Rocket, GraduationCap, Briefcase, Globe, Smartphone, Server, Cpu } from '@lucide/astro';
import { journey } from '../data/journey';

const timeline = journey.map((item) => ({
  ...item,
  icon:
    item.year === '2025'
      ? 'server'
      : item.year === '2023'
        ? 'rocket'
        : item.year === '2021' || item.year === '2016'
          ? 'graduation'
          : item.year === '2019'
            ? 'briefcase'
            : item.year === '2015'
              ? 'cpu'
              : item.year === '2014'
                ? 'smartphone'
                : item.year === '2013'
                  ? 'code'
                  : 'globe',
}));

const getIcon = (icon: string) => {
  switch (icon) {
    case 'globe': return Globe;
    case 'code': return Code;
    case 'smartphone': return Smartphone;
    case 'graduation': return GraduationCap;
    case 'briefcase': return Briefcase;
    case 'rocket': return Rocket;
    case 'server': return Server;
    case 'cpu': return Cpu;
    default: return Calendar;
  }
};
---

<BaseLayout
  title="My Journey | Apavayan Sinha"
  description="From building my first website in 2007 to architecting AI-powered government platforms in 2025 — the story of my evolution in tech."
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-500 mb-8 transition-colors"
      >
        <ArrowLeft class="w-4 h-4" />
        Back to Home
      </a>

      <header class="mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-1000 mb-6">
          My Journey
        </h1>
        <p class="text-xl text-neutral-500 dark:text-neutral-400 leading-relaxed">
          From a curious kid building HTML pages in Lucknow to architecting AI-powered systems —
          this is the story of how I fell in love with technology and never looked back.
        </p>
      </header>

      <!-- Opening Story -->
      <div class="prose mb-16">
        <p>
          It started in <strong>2007</strong> with a simple HTML page. I didn't know what "software engineering" meant,
          but I knew I wanted to build things on the internet. That first website wasn't much — but it was <em>mine</em>.
        </p>
        <p>
          That spark of creation never faded. It evolved into a tech blog helping thousands of Android users,
          contributions to open-source projects used by millions, a formal CS education, and now — architecting
          AI-powered platforms and government infrastructure.
        </p>
        <p>
          <strong>4+ years of professional experience.</strong> From React and Django to Spring Boot microservices.
          From simple websites to multi-agent LLM systems. Here's how it unfolded.
        </p>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 md:left-6 top-0 bottom-0 w-0.5 bg-linear-to-b from-primary-500 via-primary-600 to-primary-700"></div>

        <div class="space-y-12">
          {timeline.map((item, index) => {
            const IconComponent = getIcon(item.icon);
            return (
              <div class="relative pl-12 md:pl-16">
                <!-- Icon -->
                <div class={`absolute left-0 md:left-2 w-8 h-8 rounded-full flex items-center justify-center ${item.current ? 'bg-primary-600 text-white ring-4 ring-primary-100 dark:ring-primary-900/50' : 'bg-white dark:bg-black border-2 border-primary-500 text-primary-600 dark:text-primary-500'}`}>
                  <IconComponent class="w-4 h-4" />
                </div>

                <!-- Content -->
                <div class={`p-6 rounded-xl ${item.current ? 'bg-primary-50 dark:bg-primary-900/20 border border-primary-100 dark:border-primary-800' : 'bg-white dark:bg-black'}`}>
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <span class="text-2xl font-bold text-primary-600 dark:text-primary-500">
                      {item.year}
                    </span>
                    {item.current && (
                      <span class="text-xs px-2 py-1 bg-primary-600 text-white rounded animate-pulse">
                        Current
                      </span>
                    )}
                  </div>

                  <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-1000 mb-1">
                    {item.title}
                  </h3>
                  <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-3">
                    {item.subtitle}
                  </p>

                  <p class="text-neutral-500 dark:text-neutral-400 mb-4">
                    {item.description}
                  </p>

                  {item.highlight && (
                    <blockquote class="border-l-2 border-primary-500 pl-4 italic text-neutral-500 dark:text-neutral-400 mb-4">
                      {item.highlight}
                    </blockquote>
                  )}

                  <div class="flex flex-wrap gap-2">
                    {item.tech.map(t => (
                      <span class="text-xs px-2 py-1 bg-[#FAFAFA] dark:bg-neutral-600 text-neutral-500 dark:text-neutral-400 rounded border border-neutral-200 dark:border-neutral-600">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Closing -->
      <div class="mt-16 p-8 bg-linear-to-br from-primary-50 to-[#FAFAFA] dark:from-primary-900/20 dark:to-black rounded-xl text-center border border-primary-100 dark:border-primary-800/50">
        <p class="text-lg text-neutral-500 dark:text-neutral-400 mb-4">
          18 years of building. From HTML to AI. From hobby to profession.
        </p>
        <p class="text-xl font-semibold text-neutral-900 dark:text-neutral-1000">
          The best code is yet to be written.
        </p>
      </div>

      <!-- Links -->
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/blog"
          class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors"
        >
          Read My Blog Archive
        </a>
        <a
          href="/#experience"
          class="px-6 py-3 border border-neutral-200 dark:border-neutral-600 hover:bg-neutral-200 dark:hover:bg-neutral-600 rounded-lg transition-colors"
        >
          View Experience
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
