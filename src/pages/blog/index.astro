---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ArrowLeft, Calendar, Tag } from '@lucide/astro';
import { blogPosts } from '../../data/blogPosts';
---

<BaseLayout
  title="Blog Archive | Apavayan Sinha"
  description="Archived blog posts from Apavayan World - Android tips, rooting tutorials, ROMs, app reviews, and more."
>
  <section class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary-600 dark:hover:text-primary-500 mb-8 transition-colors"
      >
        <ArrowLeft class="w-4 h-4" />
        Back to Home
      </a>

      <header class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-1000 mb-4">
          Blog Archive
        </h1>
        <p class="text-lg text-neutral-500 dark:text-neutral-400">
          Posts from my old tech blog "Apavayan World" (2014-2017) - covering Android rooting, custom ROMs, and mobile tech news.
        </p>
      </header>

      <div class="space-y-8">
        {blogPosts.map(post => (
          <article class="group">
            <a href={`/blog/${post.slug}`} class="block">
              <div class="p-6 -mx-6 rounded-xl hover:bg-white dark:hover:bg-black transition-colors">
                <div class="flex items-center gap-3 text-sm text-neutral-500 dark:text-neutral-400 mb-2">
                  <span class="inline-flex items-center gap-1">
                    <Tag class="w-3 h-3" />
                    {post.category}
                  </span>
                  <span class="inline-flex items-center gap-1">
                    <Calendar class="w-3 h-3" />
                    {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                </div>
                <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-1000 group-hover:text-primary-600 dark:group-hover:text-primary-500 transition-colors mb-2">
                  {post.title}
                </h2>
                <p class="text-neutral-500 dark:text-neutral-400 line-clamp-2">
                  {post.excerpt}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
